# Copy this file to .env and fill in your actual values
# NEVER commit the real .env file - it's in .gitignore

# Database Connection (Required for production)
# Local development: postgres://postgres:postgres@localhost:5432/provue_tara
# Production (Neon): postgresql://user:password@host.neon.tech/dbname
# Production (Supabase): postgresql://postgres.xxx:password@host.supabase.co/postgres
DATABASE_URL=postgres://localhost:5432/provue_tara

# LLM Provider Configuration (Required)
# Groq is pre-configured, but you can switch to OpenAI/Anthropic
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here

# Alternative: OpenAI (uncomment to use)
# OPENAI_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4o-mini

# Alternative: Anthropic (uncomment to use)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# LLM_MODEL=claude-3-haiku-20240307

# Mastra Platform (Optional - for observability)
# Get from: https://projects.mastra.ai after running `mastra init`
MASTRA_PLATFORM_ACCESS_TOKEN=sk_your_token_here
MASTRA_PROJECT_ID=your_project_id_here

# Server Configuration (Optional)
PORT=3000
NODE_ENV=development

# For Vercel Deployment (Optional - required for production)
# These are typically set in Vercel dashboard, not here
# DATABASE_URL_PRODUCTION=postgresql://...vercel...
